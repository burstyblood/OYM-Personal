<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script>
const REFRESH_MS=300000;
const CACHE_KEY='dcWeatherCacheV3';
const DATA_MAX_AGE_MS=15*60*1000;
const SITE_CONFIG=[
 {id:'pacheco',name:'DC Pacheco',location:'General Pacheco, Buenos Aires',lat:-34.4524,lon:-58.6431,designTemp:40},
 {id:'hornos',name:'DC Hornos',location:'Barracas, CABA',lat:-34.6422,lon:-58.3776,designTemp:40},
 {id:'sanlorenzo',name:'DC San Lorenzo',location:'San Lorenzo, Santa Fe',lat:-32.7498,lon:-60.7350,designTemp:42},
 {id:'bosquealegre',name:'Bosque Alegre',location:'Sierras de Córdoba',lat:-31.5983,lon:-64.5467,designTemp:38}
];
const weatherMap={0:['Despejado','☀️'],1:['Mayormente despejado','🌤️'],2:['Parcialmente nublado','⛅'],3:['Cubierto','☁️'],45:['Niebla','🌫️'],48:['Niebla con escarcha','🌫️'],51:['Llovizna leve','🌦️'],53:['Llovizna','🌦️'],55:['Llovizna intensa','🌧️'],61:['Lluvia leve','🌦️'],63:['Lluvia','🌧️'],65:['Lluvia intensa','🌧️'],71:['Nevada leve','🌨️'],73:['Nevada','🌨️'],80:['Chaparrones leves','🌦️'],81:['Chaparrones','🌧️'],82:['Chaparrones intensos','⛈️'],95:['Tormenta','⛈️'],96:['Tormenta con granizo','⛈️'],99:['Tormenta fuerte','⛈️']};
const wx=c=>weatherMap[c]||['Condición variable','🌡️'];
const compass=d=>['N','NE','E','SE','S','SO','O','NO'][Math.round(d/45)%8];
const hh=t=>new Intl.DateTimeFormat('es-AR',{hour:'2-digit',minute:'2-digit',hour12:false}).format(new Date(t));
const num=(v,d=0)=>Number.isFinite(v)?v.toFixed(d):'--';
const safeValues=a=>(a||[]).filter(Number.isFinite);
const maxOr=(a,fallback=0)=>{const v=safeValues(a);return v.length?Math.max(...v):fallback};
const minOr=(a,fallback=0)=>{const v=safeValues(a);return v.length?Math.min(...v):fallback};
function currentHourIndex(times){const now=Date.now();let index=(times||[]).findIndex(t=>new Date(t).getTime()>=now-30*60*1000);return index<0?0:index;}
function dewPoint(temp,rh){return temp-(100-rh)/5;}
function wetBulb(temp,rh){return temp*Math.atan(.151977*Math.sqrt(rh+8.313659))+Math.atan(temp+rh)-Math.atan(rh-1.676331)+.00391838*Math.pow(rh,1.5)*Math.atan(.023101*rh)-4.686035;}
let nextRefresh=Date.now()+REFRESH_MS;
let lastResults=[];
let lastSuccessfulUpdate=null;

let radarMap=null,radarLayer=null,radarFrames=[],radarFrameIndex=0,radarTimer=null,radarMarkers=[];
function selectedSiteObjects(){return SITE_CONFIG.filter(s=>selectedSites.has(s.id));}
function radarBounds(){const sites=selectedSiteObjects();return sites.length?L.latLngBounds(sites.map(s=>[s.lat,s.lon])):L.latLngBounds(SITE_CONFIG.map(s=>[s.lat,s.lon]));}
function createRadarMap(){if(radarMap)return;radarMap=L.map('radarMap',{zoomControl:true,attributionControl:true});L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{maxZoom:18,attribution:'© OpenStreetMap'}).addTo(radarMap);updateRadarMarkers();fitRadarSites();}
function updateRadarMarkers(){if(!radarMap)return;radarMarkers.forEach(m=>m.remove());radarMarkers=[];selectedSiteObjects().forEach(site=>{const icon=L.divIcon({className:'',html:'<div class="dc-marker"></div>',iconSize:[18,18],iconAnchor:[9,9]});const marker=L.marker([site.lat,site.lon],{icon}).addTo(radarMap).bindPopup(`<strong>${site.name}</strong><br>${site.location}`);radarMarkers.push(marker);});}
function fitRadarSites(){if(!radarMap)return;const sites=selectedSiteObjects();if(sites.length===1)radarMap.setView([sites[0].lat,sites[0].lon],8);else radarMap.fitBounds(radarBounds(),{padding:[60,60],maxZoom:7});}
async function loadRadarFrames(){try{const res=await fetch('https://api.rainviewer.com/public/weather-maps.json',{cache:'no-store'});if(!res.ok)throw new Error('Radar no disponible');const data=await res.json();const past=data.radar?.past||[],nowcast=data.radar?.nowcast||[];radarFrames=[...past,...nowcast];if(!radarFrames.length)throw new Error('Sin imágenes de radar');radarFrameIndex=Math.max(0,past.length-1);showRadarFrame();startRadarAnimation();}catch(e){document.getElementById('radarTime').textContent='Radar no disponible';}}
function showRadarFrame(){if(!radarMap||!radarFrames.length)return;const frame=radarFrames[radarFrameIndex];if(radarLayer)radarMap.removeLayer(radarLayer);radarLayer=L.tileLayer(`https://tilecache.rainviewer.com${frame.path}/256/{z}/{x}/{y}/6/1_1.png`,{opacity:.72,zIndex:20,attribution:'Radar © RainViewer'}).addTo(radarMap);const when=new Date(frame.time*1000);const nowcast=radarFrameIndex>=(radarFrames.filter(f=>f.time<=Date.now()/1000).length);document.getElementById('radarTime').textContent=`${nowcast?'Pronóstico':'Observado'} ${when.toLocaleTimeString('es-AR',{hour:'2-digit',minute:'2-digit'})}`;}
function startRadarAnimation(){stopRadarAnimation();radarTimer=setInterval(()=>{radarFrameIndex=(radarFrameIndex+1)%radarFrames.length;showRadarFrame();},900);document.getElementById('radarPlay').textContent='❚❚ Pausar';document.getElementById('radarPlay').classList.add('active');}
function stopRadarAnimation(){if(radarTimer){clearInterval(radarTimer);radarTimer=null;}const b=document.getElementById('radarPlay');if(b){b.textContent='▶ Reproducir';b.classList.remove('active');}}
function openRadar(){const modal=document.getElementById('radarModal');modal.classList.add('open');modal.setAttribute('aria-hidden','false');createRadarMap();setTimeout(()=>{radarMap.invalidateSize();updateRadarMarkers();fitRadarSites();},80);loadRadarFrames();}
function closeRadar(){document.getElementById('radarModal').classList.remove('open');document.getElementById('radarModal').setAttribute('aria-hidden','true');stopRadarAnimation();}

let selectedSites=new Set(JSON.parse(localStorage.getItem('selectedSites')||'null')||SITE_CONFIG.map(s=>s.id));
function weatherApi(s){return `https://api.open-meteo.com/v1/forecast?latitude=${s.lat}&longitude=${s.lon}&current=temperature_2m,relative_humidity_2m,apparent_temperature,precipitation,weather_code,wind_speed_10m,wind_direction_10m,wind_gusts_10m,pressure_msl,visibility&hourly=temperature_2m,relative_humidity_2m,precipitation_probability,precipitation,weather_code,wind_gusts_10m,visibility&daily=temperature_2m_max,temperature_2m_min,precipitation_sum,precipitation_probability_max,sunrise,sunset&timezone=America%2FArgentina%2FBuenos_Aires&forecast_days=3`;}
function airApi(s){return `https://air-quality-api.open-meteo.com/v1/air-quality?latitude=${s.lat}&longitude=${s.lon}&current=pm2_5,pm10,us_aqi&timezone=America%2FArgentina%2FBuenos_Aires`;}
function classify(site,w,air){
 const c=w.current,h=w.hourly;
 const start=currentHourIndex(h.time),next12=a=>(a||[]).slice(start,start+12),next24=a=>(a||[]).slice(start,start+24);
 const rain12=maxOr(next12(h.precipitation_probability));
 const gust12=maxOr([c.wind_gusts_10m,...next12(h.wind_gusts_10m)]);
 const rain24=safeValues(next24(h.precipitation)).reduce((a,b)=>a+b,0);
 const minVis=minOr([c.visibility,...next12(h.visibility)],99999);
 const forecastMaxTemp=maxOr([c.temperature_2m,...next12(h.temperature_2m)],c.temperature_2m);
 const margin=site.designTemp-forecastMaxTemp;
 const temps12=next12(h.temperature_2m),times12=next12(h.time);
 const validTempIndexes=temps12.map((value,index)=>({value,index})).filter(x=>Number.isFinite(x.value));
 const lowestPoint=validTempIndexes.length?validTempIndexes.reduce((a,b)=>b.value<a.value?b:a):{value:c.temperature_2m,index:0};
 const lowStart=Math.max(0,lowestPoint.index-1),lowEnd=Math.min(times12.length-1,lowestPoint.index+1);
 const lowWindow=times12.length?`${hh(times12[lowStart])}–${hh(times12[lowEnd])}`:'sin datos';
 const codes=[c.weather_code,...next12(h.weather_code)].filter(Number.isFinite);
 const dew=dewPoint(c.temperature_2m,c.relative_humidity_2m),wet=wetBulb(c.temperature_2m,c.relative_humidity_2m);
 let score=0,reasons=[],actions=[];

 if(margin<=0){score+=35;reasons.push('máxima prevista igual o superior al diseño');actions.push('No iniciar una parada de chillers; verificar capacidad y redundancia disponible.');}
 else if(margin<=2){score+=22;reasons.push('margen térmico previsto menor o igual a 2 °C');actions.push('Conservar capacidad activa y controlar temperaturas de impulsión, retorno y salas.');}
 else if(margin<=4){score+=12;reasons.push('margen térmico previsto reducido');actions.push('Verificar autonomía real del tanque antes de cualquier optimización.');}
 else if(margin<=8){score+=5;reasons.push('margen térmico previsto moderado');}

 if(wet>=28){score+=15;reasons.push('bulbo húmedo muy elevado');actions.push('Validar rendimiento real de torres/chillers y condición N+1.');}
 else if(wet>=25){score+=8;reasons.push('bulbo húmedo elevado');actions.push('Revisar capacidad de rechazo de calor antes de reducir equipos en servicio.');}

 if(gust12>80){score+=25;reasons.push('ráfagas superiores a 80 km/h');actions.push('Suspender tareas exteriores, en altura, cubierta e izajes.');}
 else if(gust12>=60){score+=15;reasons.push('ráfagas fuertes');actions.push('Suspender altura e izajes y asegurar elementos exteriores.');}
 else if(gust12>=45){score+=8;reasons.push('ráfagas moderadas');actions.push('Revisar restricciones para tareas exteriores.');}

 if(rain24>50){score+=22;reasons.push('precipitación prevista superior a 50 mm/24 h');actions.push('Verificar drenajes, cámaras, subsuelos y accesos; realizar ronda preventiva.');}
 else if(rain24>=30){score+=12;reasons.push('precipitación prevista de 30 a 50 mm/24 h');actions.push('Verificar drenajes, cámaras y accesos al predio.');}
 else if(rain24>=15){score+=5;reasons.push('precipitación prevista de 15 a 30 mm/24 h');actions.push('Inspeccionar preventivamente exteriores y desagües.');}
 else if(rain12>=80){score+=5;reasons.push('alta probabilidad de lluvia');}

 if(codes.some(code=>[96,99].includes(code))){score+=25;reasons.push('tormenta fuerte o con granizo prevista');actions.push('Suspender tareas exteriores y reforzar el seguimiento de energía y refrigeración.');}
 else if(codes.includes(95)){score+=15;reasons.push('tormenta eléctrica prevista');actions.push('Confirmar disponibilidad de GE, UPS, bombas y refrigeración.');}

 if(minVis<500){score+=15;reasons.push('visibilidad crítica');actions.push('Evaluar la restricción de ingresos no esenciales.');}
 else if(minVis<2000){score+=8;reasons.push('visibilidad reducida');actions.push('Advertir al personal y proveedores sobre los accesos.');}
 else if(minVis<5000){score+=3;reasons.push('visibilidad moderadamente reducida');}

 if(c.relative_humidity_2m>=90){reasons.push('humedad exterior extrema');actions.push('Revisar condensación en tomas, filtros y salas de transición.');}
 if((air?.current?.us_aqi||0)>=101){reasons.push('calidad de aire desfavorable');actions.push('Evaluar filtros y evitar economización con aire exterior.');}

 score=Math.min(100,score);
 const level=score>=60?'critical':score>=40?'high':score>=20?'preventive':'normal';
 const labels={critical:'CRÍTICO',high:'ALTO',preventive:'PREVENTIVO',normal:'NORMAL'};
 if(!actions.length)actions.push('Sin restricciones meteorológicas relevantes.');
 return {score,level,label:labels[level],dew,wet,reasons:reasons.length?reasons.join(', '):'sin amenazas relevantes',actions,rain12,gust12,rain24,minVis,margin,forecastMaxTemp,lowestTemp:lowestPoint.value,lowWindow};
}
function coolingRecommendation(r){
 const common='Validar siempre en Metasys el nivel y la estratificación del tanque, temperaturas de impulsión/retorno y salas, caudal, bombas, alarmas y redundancia.';
 if(r.level==='critical')return {mode:'REFRIGERACIÓN PRIORITARIA',text:'Suspender la optimización energética. Mantener o restablecer la capacidad definida para contingencia y recuperar reserva térmica según procedimiento. '+common};
 if(r.level==='high')return {mode:'RECUPERAR / CONSERVAR RESERVA',text:'No iniciar una parada de chillers. Mantener la capacidad mínima necesaria para sostener carga y conservar o recuperar el tanque por encima del 50%. '+common};
 if(r.level==='preventive')return {mode:'OPTIMIZACIÓN CONDICIONADA',text:'No iniciar una nueva parada de chillers. Si el tanque ya está en descarga, detener su utilización al alcanzar el 50% y recuperar reserva térmica. '+common};
 return {mode:'APTO PARA EVALUAR DESCARGA',text:`Condiciones meteorológicas favorables. Evaluar la parada de chillers únicamente en la franja de menor temperatura prevista (${r.lowWindow}, mínima aproximada ${num(r.lowestTemp,1)} °C). Utilizar como máximo el 50% del tanque y conservar el 50% restante como reserva. Sin alarmas ni pérdida de redundancia. `+common};
}
async function getSite(site){const [wr,ar]=await Promise.all([fetch(weatherApi(site)),fetch(airApi(site))]);if(!wr.ok)throw new Error('Error meteorológico');const weather=await wr.json();let air=null;try{if(ar.ok)air=await ar.json()}catch(e){}return {site,weather,air};}
async function loadAll(){const btn=document.getElementById('refresh');btn.disabled=true;document.getElementById('updated').textContent='Actualizando…';try{const settled=await Promise.allSettled(SITE_CONFIG.map(getSite));const fresh=settled.filter(x=>x.status==='fulfilled').map(x=>x.value);const previous=new Map(lastResults.map(r=>[r.site.id,r]));fresh.forEach(r=>previous.set(r.site.id,r));lastResults=[...previous.values()];if(!fresh.length)throw new Error('Sin respuestas válidas');lastSuccessfulUpdate=new Date();localStorage.setItem(CACHE_KEY,JSON.stringify({at:lastSuccessfulUpdate.toISOString(),results:lastResults}));renderFiltered();const partial=fresh.length<SITE_CONFIG.length;document.getElementById('updated').textContent=`${partial?'Datos parciales':'Actualizado'} ${hh(lastSuccessfulUpdate)}`;document.getElementById('updated').classList.toggle('stale',partial);const banner=document.getElementById('banner');banner.textContent=partial?`${SITE_CONFIG.length-fresh.length} sitio(s) sin respuesta; se mantiene su última lectura válida.`:'';banner.classList.toggle('show',partial);nextRefresh=Date.now()+REFRESH_MS;}catch(e){document.getElementById('banner').textContent='No fue posible actualizar. Se conserva la última lectura disponible; validar Metasys y avisos oficiales.';document.getElementById('banner').classList.add('show');document.getElementById('updated').textContent=lastSuccessfulUpdate?`Último dato ${hh(lastSuccessfulUpdate)}`:'Sin datos';document.getElementById('updated').classList.add('stale');renderFiltered();}finally{btn.disabled=false}}
function restoreCache(){try{const cache=JSON.parse(localStorage.getItem(CACHE_KEY)||'null');if(!cache?.results?.length)return;lastResults=cache.results;lastSuccessfulUpdate=new Date(cache.at);renderFiltered();const age=Date.now()-lastSuccessfulUpdate.getTime();document.getElementById('updated').textContent=`Caché ${hh(lastSuccessfulUpdate)}`;document.getElementById('updated').classList.toggle('stale',age>DATA_MAX_AGE_MS);}catch(e){localStorage.removeItem(CACHE_KEY);}}
function renderFiltered(){
 const results=lastResults.filter(r=>selectedSites.has(r.site.id));
 const grid=document.getElementById('grid');
 grid.className='grid count-'+results.length;
 if(!results.length){document.getElementById('overview').innerHTML='';grid.innerHTML='<div class="loading">Seleccioná al menos un datacenter para mostrar.</div>';return;}
 const evaluations=results.map(r=>classify(r.site,r.weather,r.air));
 const counts={critical:0,high:0,preventive:0,normal:0};
 evaluations.forEach(x=>counts[x.level]++);
 const order=['normal','preventive','high','critical'];
 const globalLevel=order[Math.max(...evaluations.map(x=>order.indexOf(x.level)))];
 const globalLabels={critical:'Crítico',high:'Alto',preventive:'Preventivo',normal:'Normal'};
 const temps=results.map(r=>r.weather.current.temperature_2m);
 const maxScore=Math.max(...evaluations.map(x=>x.score));
 const minMargin=Math.min(...evaluations.map(x=>x.margin));
 document.getElementById('overview').innerHTML=`
<div class="summary"><div class="summary-label">Estado global</div><div class="summary-value">${globalLabels[globalLevel]}</div><div class="summary-note">${counts.critical} críticos · ${counts.high} altos · ${counts.preventive} preventivos</div></div>
<div class="summary"><div class="summary-label">Riesgo máximo</div><div class="summary-value">${maxScore}/100</div><div class="summary-note">Índice meteorológico preventivo</div></div>
<div class="summary"><div class="summary-label">Rango térmico</div><div class="summary-value">${Math.round(Math.min(...temps))}° / ${Math.round(Math.max(...temps))}°</div><div class="summary-note">Temperatura exterior actual</div></div>
<div class="summary"><div class="summary-label">Margen mínimo previsto</div><div class="summary-value">${num(minMargin,1)} °C</div><div class="summary-note">Máxima 12 h vs. diseño</div></div>
<div class="summary"><div class="summary-label">Sitios monitoreados</div><div class="summary-value">${results.length}</div><div class="summary-note">Actualización cada 5 min</div></div>`;
 grid.innerHTML=results.map(({site,weather,air})=>{
  const c=weather.current,[cond,icon]=wx(c.weather_code),r=classify(site,weather,air),cooling=coolingRecommendation(r);
  const daily=weather.daily,start=currentHourIndex(weather.hourly.time);
  const forecast=weather.hourly.time.slice(start,start+8).map((t,offset)=>{const i=start+offset,[,ic]=wx(weather.hourly.weather_code[i]);return `<div class="hour"><div class="hour-time">${offset===0?'Ahora':hh(t)}</div><div class="hour-icon" style="font-size:300%">${ic}</div><div class="hour-temp">${Math.round(weather.hourly.temperature_2m[i])}°</div><div class="hour-rain">${weather.hourly.precipitation_probability[i]??'--'}%</div></div>`}).join('');
  return `<article class="site">
<div class="site-head"><div><div class="site-name">${site.name}</div><div class="site-location">${site.location}</div><a class="site-link" href="sitio-${site.id}.html">Ver detalle y mapa satelital →</a></div><div class="status ${r.level}">${r.label}</div></div>
<div class="mainrow"><section class="weather"><div class="weather-top"><div><div class="temp">${Math.round(c.temperature_2m)}<sup>°C</sup></div><div class="condition">${cond}</div><div class="feels">Sensación térmica ${Math.round(c.apparent_temperature)} °C</div></div><div class="icon">${icon}</div></div><div class="design"><span>Temperatura de diseño <strong>${site.designTemp} °C</strong></span><span>Margen previsto 12 h <strong>${num(r.margin,1)} °C</strong></span></div></section>
<section class="risk risk-main"><div class="score"><div class="score-number">${r.score}</div><div class="score-label">RIESGO / 100</div></div><div class="advice"><strong>Lectura operativa: ${r.reasons}.</strong>${r.actions.map(a=>'• '+a).join('<br>')}<div class="thermal"><b>${cooling.mode}:</b> ${cooling.text}</div></div></section></div>
<div class="metrics"><div class="metric"><div class="metric-label">Bulbo húmedo</div><div class="metric-value">${num(r.wet,1)} °C</div></div><div class="metric"><div class="metric-label">Máxima 12 h</div><div class="metric-value">${num(r.forecastMaxTemp,1)} °C</div></div><div class="metric"><div class="metric-label">Ráfaga 12 h</div><div class="metric-value">${Math.round(r.gust12)} km/h</div></div><div class="metric"><div class="metric-label">Lluvia 24 h</div><div class="metric-value">${num(r.rain24,1)} mm</div></div><div class="metric"><div class="metric-label">Visibilidad mín.</div><div class="metric-value">${num(r.minVis/1000,1)} km</div></div><div class="metric"><div class="metric-label">Punto de rocío</div><div class="metric-value">${num(r.dew,1)} °C</div></div></div>
<div class="forecast">${forecast}</div><div class="updated-site">Máx. diaria ${Math.round(daily.temperature_2m_max[0])} °C · Lluvia diaria ${num(daily.precipitation_sum[0],1)} mm · Amanecer ${hh(daily.sunrise[0])} · Atardecer ${hh(daily.sunset[0])}</div></article>`;
 }).join('');
}
function updateConnectivity(){const online=navigator.onLine;const el=document.getElementById('connection');el.textContent=online?'● En línea':'● Sin conexión';el.style.color=online?'var(--green)':'var(--red)'}
function tick(){const remaining=Math.max(0,nextRefresh-Date.now());const min=Math.floor(remaining/60000),sec=Math.floor((remaining%60000)/1000);document.getElementById('countdown').textContent=`Próxima actualización ${String(min).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;if(remaining<=0){nextRefresh=Date.now()+REFRESH_MS;loadAll()}}
function updateSelectorLabel(){const n=selectedSites.size;const btn=document.getElementById('selectorBtn');btn.textContent=n===SITE_CONFIG.length?'Sitios: Todos ▾':n===0?'Sitios: Ninguno ▾':`Sitios: ${n} seleccionados ▾`;}
function persistSelection(){updateRadarMarkers();localStorage.setItem('selectedSites',JSON.stringify([...selectedSites]));updateSelectorLabel();renderFiltered();}
function initSelector(){const box=document.getElementById('selectorOptions');box.innerHTML=SITE_CONFIG.map(s=>`<label class="selector-option"><input type="checkbox" value="${s.id}" ${selectedSites.has(s.id)?'checked':''}> <span>${s.name}</span></label>`).join('');box.addEventListener('change',e=>{if(e.target.matches('input[type=checkbox]')){e.target.checked?selectedSites.add(e.target.value):selectedSites.delete(e.target.value);persistSelection();}});document.getElementById('selectorBtn').addEventListener('click',e=>{e.stopPropagation();document.getElementById('selectorMenu').classList.toggle('open')});document.getElementById('selectAll').addEventListener('click',()=>{selectedSites=new Set(SITE_CONFIG.map(s=>s.id));initSelector();persistSelection();document.getElementById('selectorMenu').classList.add('open')});document.getElementById('clearAll').addEventListener('click',()=>{selectedSites.clear();initSelector();persistSelection();document.getElementById('selectorMenu').classList.add('open')});document.addEventListener('click',e=>{if(!e.target.closest('.site-selector'))document.getElementById('selectorMenu').classList.remove('open')});updateSelectorLabel();}
initSelector();
document.getElementById('openRadar').addEventListener('click',openRadar);document.getElementById('radarClose').addEventListener('click',closeRadar);document.getElementById('radarFit').addEventListener('click',fitRadarSites);document.getElementById('radarPlay').addEventListener('click',()=>radarTimer?stopRadarAnimation():startRadarAnimation());document.addEventListener('keydown',e=>{if(e.key==='Escape')closeRadar()});document.getElementById('refresh').addEventListener('click',loadAll);window.addEventListener('online',()=>{updateConnectivity();loadAll()});window.addEventListener('offline',updateConnectivity);updateConnectivity();restoreCache();loadAll();setInterval(tick,1000);
</script>
</body>
</html>

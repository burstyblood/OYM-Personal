<style>
:root{--bg:#06101d;--panel:#0d2138;--panel2:#132d4c;--line:rgba(255,255,255,.10);--text:#f7fbff;--muted:#a7b8cc;--blue:#6ec1ff;--green:#6fe0b4;--amber:#ffc86b;--red:#ff7b7b;--purple:#c9a7ff;--shadow:0 18px 45px rgba(0,0,0,.30)}
*{box-sizing:border-box}html,body{margin:0;width:100%;height:100%;overflow:hidden}body{color:var(--text);font-family:Manrope,system-ui,-apple-system,"Segoe UI",sans-serif;font-size:16px;background:radial-gradient(circle at 95% 0,rgba(70,151,255,.17),transparent 28%),linear-gradient(145deg,#050d18,#0a1930 62%,#07111f)}
.page{width:100vw;height:100vh;padding:1.2vh 1.2vw;display:flex;flex-direction:column;gap:1vh}.top{display:flex;justify-content:space-between;align-items:center;gap:1vw;min-height:8.5vh}.eyebrow{color:var(--green);font-size:clamp(13px,.78vw,19px);font-weight:800;letter-spacing:.14em;text-transform:uppercase}h1{font-size:clamp(32px,2.8vw,60px);line-height:1;margin:.4vh 0;letter-spacing:-.045em}.subtitle{margin:0;color:var(--muted);font-size:clamp(15px,.92vw,21px)}.controls{display:flex;flex-wrap:wrap;gap:.45vw;justify-content:flex-end;max-width:48vw}.pill,.btn{border:1px solid var(--line);background:rgba(255,255,255,.045);padding:.65vh .75vw;border-radius:999px;font-size:clamp(12px,.72vw,17px)}.pill{color:var(--muted)}.btn{color:var(--text);font-weight:750;cursor:pointer}.site-selector{position:relative}.selector-btn{border:1px solid var(--line);background:rgba(255,255,255,.045);color:var(--text);padding:.65vh .85vw;border-radius:999px;font-size:clamp(12px,.72vw,17px);font-weight:750;cursor:pointer;min-width:12vw;text-align:left}.selector-menu{display:none;position:absolute;right:0;top:calc(100% + .5vh);z-index:50;width:18vw;min-width:280px;padding:.7vh .7vw;border:1px solid var(--line);border-radius:.8vw;background:#0b1d32;box-shadow:var(--shadow)}.selector-menu.open{display:block}.selector-title{font-size:clamp(10px,.62vw,14px);color:var(--muted);margin-bottom:.5vh}.selector-option{display:flex;align-items:center;gap:.55vw;padding:.48vh .35vw;border-radius:.45vw;font-size:clamp(11px,.68vw,15px);cursor:pointer}.selector-option:hover{background:rgba(255,255,255,.05)}.selector-option input{width:1vw;height:1vw;min-width:16px;min-height:16px;accent-color:#6ec1ff}.selector-actions{display:flex;gap:.4vw;margin-top:.55vh;padding-top:.55vh;border-top:1px solid var(--line)}.selector-actions button{flex:1;border:1px solid var(--line);background:rgba(255,255,255,.04);color:var(--text);border-radius:.5vw;padding:.45vh .4vw;cursor:pointer;font-weight:700}.banner{display:none;padding:.8vh .8vw;border-radius:12px;border:1px solid rgba(255,123,123,.3);background:rgba(255,123,123,.1);color:#ffd3d3;font-size:.8vw}.banner.show{display:block}.pill.stale{color:var(--amber);border-color:rgba(255,200,107,.35)}
.overview{display:grid;grid-template-columns:repeat(5,1fr);gap:.65vw;min-height:9vh}.summary{background:rgba(14,32,53,.88);border:1px solid var(--line);border-radius:1vw;padding:1vh .9vw;box-shadow:var(--shadow)}.summary-label{font-size:clamp(12px,.7vw,16px);color:var(--muted)}.summary-value{font-size:clamp(22px,1.65vw,36px);font-weight:880;margin-top:.25vh}.summary-note{font-size:clamp(11px,.62vw,14px);color:var(--muted);margin-top:.25vh}
.grid{flex:1;min-height:0;display:grid;gap:.8vw}.grid.count-1{grid-template-columns:1fr;grid-template-rows:1fr}.grid.count-2{grid-template-columns:repeat(2,minmax(0,1fr));grid-template-rows:1fr}.grid.count-3,.grid.count-4{grid-template-columns:repeat(2,minmax(0,1fr));grid-template-rows:repeat(2,minmax(0,1fr))}.grid.count-3 .site:first-child{grid-column:1/-1}.site{background:linear-gradient(155deg,rgba(18,40,67,.98),rgba(9,25,44,.96));border:1px solid var(--line);border-radius:1.25vw;padding:1.05vh .9vw;box-shadow:var(--shadow);position:relative;overflow:hidden;display:flex;flex-direction:column}.site:after{content:"";position:absolute;width:14vw;height:14vw;border-radius:50%;right:-6vw;top:-8vw;background:radial-gradient(circle,rgba(110,193,255,.14),transparent 68%)}.site-head{display:flex;justify-content:space-between;gap:.8vw;position:relative;z-index:1}.site-name{font-size:clamp(20px,1.45vw,32px);font-weight:860}.site-location{color:var(--muted);font-size:clamp(12px,.74vw,16px);margin-top:.15vh}.site-link{display:inline-flex;color:var(--blue);font-size:clamp(11px,.68vw,15px);font-weight:800;text-decoration:none;margin-top:.3vh}.site-link:hover{text-decoration:underline}.status{display:inline-flex;align-items:center;gap:.4vw;padding:.55vh .65vw;border-radius:999px;font-size:clamp(12px,.74vw,16px);font-weight:850;border:1px solid var(--line);white-space:nowrap}.status:before{content:"";width:.55vw;height:.55vw;min-width:8px;min-height:8px;border-radius:50%;background:currentColor}.ok{color:var(--green);background:rgba(111,224,180,.08)}.watch{color:var(--amber);background:rgba(255,200,107,.09)}.alert{color:var(--red);background:rgba(255,123,123,.09)}
.normal{color:var(--green);background:rgba(111,224,180,.08)}.preventive{color:var(--blue);background:rgba(110,193,255,.09)}.high{color:var(--amber);background:rgba(255,200,107,.09)}.critical{color:var(--red);background:rgba(255,123,123,.09)}
.mainrow{display:grid;grid-template-columns:.9fr 1.35fr;gap:.65vw;margin-top:.8vh;position:relative;z-index:1}.weather{background:rgba(255,255,255,.025);border:1px solid var(--line);border-radius:.9vw;padding:.8vh .7vw}.weather-top{display:flex;justify-content:space-between;align-items:center}.temp{font-size:clamp(42px,3.3vw,72px);font-weight:920;letter-spacing:-.07em;line-height:.88}.temp sup{font-size:.27em;vertical-align:top;margin-left:.2vw}.icon{font-size:clamp(34px,2.7vw,58px)}.condition{font-weight:780;margin-top:.55vh;font-size:clamp(11px,.78vw,17px)}.feels{font-size:clamp(11px,.68vw,15px);color:var(--muted);margin-top:.15vh}.design{margin-top:.65vh;padding-top:.6vh;border-top:1px solid var(--line);display:flex;justify-content:space-between;gap:.5vw;font-size:clamp(11px,.64vw,14px)}.design strong{font-size:clamp(10px,.67vw,15px)}
.metrics{display:grid;grid-template-columns:repeat(6,1fr);gap:.38vw;margin-top:.65vh}.metric{background:rgba(255,255,255,.035);border:1px solid var(--line);border-radius:.65vw;padding:.55vh .45vw;min-width:0}.metric-label{font-size:clamp(10px,.58vw,13px);color:var(--muted);white-space:nowrap}.metric-value{font-size:clamp(12px,.74vw,16px);font-weight:790;margin-top:.25vh;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.risk{display:grid;grid-template-columns:5.4vw 1fr;gap:.55vw}.risk-main{margin:0}.score{border-radius:.8vw;border:1px solid var(--line);padding:.8vh .4vw;text-align:center;background:rgba(255,255,255,.035);display:flex;flex-direction:column;justify-content:center}.score-number{font-size:clamp(25px,2vw,44px);font-weight:900}.score-label{font-size:clamp(10px,.58vw,13px);color:var(--muted)}.advice{border-radius:.8vw;border:1px solid rgba(110,193,255,.16);background:rgba(110,193,255,.065);padding:.7vh .7vw;font-size:clamp(11px,.67vw,15px);line-height:1.35;display:flex;flex-direction:column;justify-content:center}.advice strong{display:block;margin-bottom:.3vh}
.thermal{margin-top:.45vh;padding-top:.45vh;border-top:1px solid rgba(255,255,255,.10);color:#e7f4ff}.thermal b{color:var(--green)}
.forecast{display:grid;grid-template-columns:repeat(8,1fr);gap:.34vw;margin-top:.65vh}.hour{text-align:center;padding:.45vh .15vw;border-radius:.62vw;background:rgba(255,255,255,.03);border:1px solid var(--line)}.hour-time{font-size:clamp(10px,.55vw,12px);color:var(--muted)}.hour-icon{font-size:clamp(15px,1.05vw,23px);margin:.18vh 0}.hour-temp{font-size:clamp(11px,.64vw,14px);font-weight:800}.hour-rain{font-size:clamp(10px,.53vw,12px);color:var(--blue);margin-top:.1vh}.updated-site{margin-top:auto;padding-top:.45vh;text-align:right;color:var(--muted);font-size:clamp(10px,.55vw,12px)}
.loading,.error{grid-column:1/-1;padding:3vh;text-align:center;border:1px solid var(--line);border-radius:1vw;background:rgba(14,32,53,.82);color:var(--muted)}.thresholds{display:flex;justify-content:center;gap:1vw;flex-wrap:wrap}.thresholds span{white-space:nowrap}.thresholds b{color:var(--text)}footer{text-align:center;color:var(--muted);font-size:clamp(10px,.57vw,13px);line-height:1.3;min-height:1.5vh}

.radar-btn{border:1px solid rgba(110,193,255,.35);background:rgba(110,193,255,.12);color:var(--text);padding:.65vh .85vw;border-radius:999px;font-size:clamp(12px,.72vw,17px);font-weight:800;cursor:pointer}.radar-modal{display:none;position:fixed;inset:0;z-index:1000;background:rgba(2,8,15,.94);backdrop-filter:blur(8px);padding:1.2vh 1.2vw}.radar-modal.open{display:flex;flex-direction:column}.radar-head{display:flex;align-items:center;justify-content:space-between;gap:1vw;margin-bottom:.8vh}.radar-title{font-size:clamp(24px,2vw,44px);font-weight:900}.radar-subtitle{color:var(--muted);font-size:clamp(11px,.72vw,17px);margin-top:.2vh}.radar-actions{display:flex;align-items:center;gap:.5vw;flex-wrap:wrap;justify-content:flex-end}.radar-chip,.radar-control{border:1px solid var(--line);background:rgba(255,255,255,.055);color:var(--text);border-radius:999px;padding:.65vh .75vw;font-size:clamp(12px,.7vw,16px)}.radar-control{font-weight:800;cursor:pointer}.radar-control.active{background:rgba(110,193,255,.18);border-color:rgba(110,193,255,.45)}#radarMap{flex:1;min-height:0;border-radius:1.1vw;border:1px solid var(--line);overflow:hidden;box-shadow:var(--shadow);background:#07111f}.radar-footer{display:flex;justify-content:space-between;gap:1vw;color:var(--muted);font-size:clamp(9px,.55vw,13px);padding-top:.55vh}.radar-legend{display:flex;align-items:center;gap:.45vw}.legend-bar{width:12vw;height:.8vh;border-radius:999px;background:linear-gradient(90deg,#4c96ff,#35d3ff,#53e36b,#ffe45b,#ff993b,#ff4b4b,#d430d4)}.leaflet-container{font-family:Manrope,system-ui,-apple-system,"Segoe UI",sans-serif}.leaflet-popup-content-wrapper,.leaflet-popup-tip{background:#0d2138;color:#f7fbff}.dc-marker{width:18px;height:18px;border-radius:50%;background:#6ec1ff;border:3px solid white;box-shadow:0 0 0 5px rgba(110,193,255,.25),0 2px 12px rgba(0,0,0,.55)}
/* Variante Black: identidad sobria para sala de monitoreo */
:root{--bg:#000;--panel:#090909;--panel2:#111;--line:rgba(255,255,255,.12);--text:#f7f7f7;--muted:#9da5af;--blue:#5bc0ff;--green:#62dfae;--amber:#ffc45e;--red:#ff6f76;--shadow:0 18px 48px rgba(0,0,0,.62)}
body{background:radial-gradient(circle at 88% -12%,rgba(0,174,239,.12),transparent 26%),radial-gradient(circle at 10% 110%,rgba(90,58,180,.10),transparent 30%),#000}
.brand-block{display:flex;align-items:center;gap:1vw;min-width:0}.personal-logo{width:clamp(84px,6.4vw,138px);height:clamp(40px,3.1vw,66px);flex:0 0 auto;border-radius:.7vw;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#00b7ee 0%,#008fe0 58%,#6254d9 100%);color:#fff;font-size:clamp(17px,1.25vw,28px);font-weight:800;letter-spacing:-.055em;box-shadow:0 12px 30px rgba(0,158,229,.18);border:1px solid rgba(255,255,255,.18)}
.summary{background:rgba(10,10,10,.96)}.site{background:linear-gradient(155deg,rgba(17,17,17,.99),rgba(4,4,4,.99))}.site:after{background:radial-gradient(circle,rgba(0,174,239,.10),transparent 68%)}
.weather,.metric,.hour,.score{background:rgba(255,255,255,.025)}.advice{background:rgba(0,174,239,.045);border-color:rgba(91,192,255,.18)}
.selector-menu{background:#090909}.loading,.error{background:rgba(8,8,8,.96)}.radar-modal{background:rgba(0,0,0,.96)}#radarMap{background:#050505}.leaflet-popup-content-wrapper,.leaflet-popup-tip{background:#101010;color:#f7f7f7}
/* Escala visual uniforme: toda la interfaz responde a la dimensión menor de la ventana. */
html{font-size:clamp(14px,calc(9px + .65vmin),24px)}
body{font-size:1rem}
.page{padding:1.15vmin;gap:.9vmin}
.top{display:grid;grid-template-columns:minmax(0,1fr) auto minmax(0,1fr);align-items:center;gap:1.2vmin;min-height:9.2vh}
.title-block{min-width:0}.title-block h1{font-size:2.25rem;line-height:1.02;margin:.25rem 0}.eyebrow{font-size:.78rem}.subtitle{font-size:.86rem}
.personal-logo{position:static;justify-self:center;width:7.4rem;height:3.15rem;border-radius:.65rem;font-size:1.35rem}
.controls{max-width:none;width:100%;gap:.4rem;justify-content:flex-end}.pill,.btn,.selector-btn,.radar-btn{font-size:.72rem;padding:.48rem .62rem}.selector-btn{min-width:9.5rem}
.overview{gap:.65vmin;min-height:9vh}.summary{padding:.72rem .78rem;border-radius:.8rem}.summary-label{font-size:.72rem}.summary-value{font-size:1.55rem}.summary-note{font-size:.66rem}
.grid{gap:.75vmin}.site{min-width:0;padding:.78rem .72rem;border-radius:1rem}.site-head,.mainrow,.mainrow>*{min-width:0}.site-name{font-size:1.35rem}.site-location,.site-link{font-size:.72rem}.status{font-size:.72rem;padding:.38rem .55rem}
.mainrow{gap:.58rem;margin-top:.55rem}.weather{padding:.72rem;border-radius:.72rem;font-size:clamp(14px,1.35vmin,24px)}.temp{font-size:450%;line-height:.88}.icon{font-size:330%;line-height:1}.condition{font-size:115%}.feels{font-size:90%}.design{font-size:86%;margin-top:.55rem;padding-top:.5rem}.design strong{font-size:105%}
.risk{grid-template-columns:4.8rem minmax(0,1fr);gap:.5rem}.score{padding:.62rem .3rem}.score-number{font-size:1.9rem}.score-label{font-size:.63rem}.advice{font-size:.73rem;padding:.58rem;overflow-wrap:anywhere}.thermal{margin-top:.36rem;padding-top:.36rem}
.metrics{grid-template-columns:repeat(6,minmax(0,1fr));gap:.35rem;margin-top:.52rem}.metric{padding:.48rem .4rem;border-radius:.55rem}.metric-label{font-size:.66rem}.metric-value{font-size:.77rem}
.forecast{grid-template-columns:repeat(8,minmax(0,1fr));gap:.38rem;margin-top:.58rem}.hour{font-size:clamp(14px,1.35vmin,24px);padding:4% 2%;border-radius:.58rem;min-height:clamp(7rem,12vmin,11rem);display:flex;flex-direction:column;align-items:center;justify-content:center}.hour-time{font-size:90%}.hour-icon{font-size:300%;line-height:1.1;margin:5% 0}.hour-temp{font-size:125%;font-weight:850}.hour-rain{font-size:110%;font-weight:750;margin-top:2%}.updated-site{font-size:clamp(.78rem,1.05vmin,1.1rem);padding-top:.42rem}
footer{font-size:.62rem}.thresholds{gap:.75rem}.selector-menu{font-size:.78rem}.selector-title,.selector-option{font-size:.74rem}
@media(max-width:1400px){
 html,body{overflow:auto}.page{height:auto;min-height:100vh}.overview{grid-template-columns:repeat(3,minmax(0,1fr))}.grid.count-3,.grid.count-4{grid-template-columns:repeat(2,minmax(0,1fr))}.site{min-height:390px}
}
@media(max-width:980px){
 .top{position:relative;grid-template-columns:1fr;padding-top:4.1rem}.personal-logo{position:absolute;top:0;left:50%;transform:translateX(-50%)}.controls{grid-column:1}.overview{grid-template-columns:repeat(2,minmax(0,1fr))}.grid,.grid.count-1,.grid.count-2,.grid.count-3,.grid.count-4{grid-template-columns:1fr;grid-template-rows:auto}.grid.count-3 .site:first-child{grid-column:auto}.site{min-height:0}.mainrow{grid-template-columns:1fr}.metrics{grid-template-columns:repeat(3,minmax(0,1fr))}.forecast{grid-template-columns:repeat(4,minmax(0,1fr))}
}
@media(max-width:560px){
 .overview{grid-template-columns:1fr}.metrics{grid-template-columns:repeat(2,minmax(0,1fr))}.forecast{grid-template-columns:repeat(2,minmax(0,1fr))}.controls{gap:.35rem}.pill,.btn,.selector-btn,.radar-btn{font-size:.68rem}.risk{grid-template-columns:4.2rem minmax(0,1fr)}
}
@media(max-aspect-ratio:4/3){html,body{overflow:auto}.page{height:auto;min-height:100vh}.grid,.grid.count-1,.grid.count-2,.grid.count-3,.grid.count-4{grid-template-columns:1fr;grid-template-rows:auto}.grid.count-3 .site:first-child{grid-column:auto}.controls{max-width:none}}
/* V3.3 · Sistema tipográfico único. Cada contenedor define una base responsive
   y todos sus elementos internos escalan exclusivamente por porcentaje. */
:root{--type-ui:clamp(15px,1.35vmin,26px);--type-card:clamp(15px,1.5vmin,28px);--type-detail:clamp(14px,1.25vmin,24px)}
.top{font-size:var(--type-ui)}
.title-block h1{font-size:230%}.eyebrow{font-size:78%}.subtitle{font-size:90%}.personal-logo{width:clamp(8rem,10vmin,13rem);height:auto;padding:0;background:transparent;border:0;border-radius:0;box-shadow:none}.personal-logo svg{display:block;width:100%;height:auto}
.controls{font-size:var(--type-ui)}.pill,.btn,.selector-btn,.radar-btn{font-size:74%}
.selector-menu{font-size:var(--type-ui)}.selector-title{font-size:70%}.selector-option{font-size:78%}.selector-actions button{font-size:76%}
.banner{font-size:calc(var(--type-ui) * .78)}
.overview{font-size:var(--type-card)}.summary{font-size:100%}.summary-label{font-size:75%}.summary-value{font-size:180%}.summary-note{font-size:70%}
.grid{font-size:var(--type-card)}.site{font-size:100%}.site-name{font-size:140%}.site-location{font-size:76%}.site-link{font-size:74%}.status{font-size:74%}
.weather{font-size:100%}.temp{font-size:450%}.temp sup{font-size:27%}.icon{font-size:330%}.condition{font-size:115%}.feels{font-size:90%}.design{font-size:86%}.design strong{font-size:105%}
.risk{font-size:100%}.score{font-size:100%}.score-number{font-size:205%}.score-label{font-size:66%}.advice{font-size:78%}.advice strong{font-size:100%}.thermal{font-size:100%}.thermal b{font-size:100%}
.metrics{font-size:100%}.metric{font-size:100%}.metric-label{font-size:70%}.metric-value{font-size:86%}
.forecast{font-size:100%}.hour{font-size:100%}.hour-time{font-size:82%}.hour-icon{font-size:300%}.hour-temp{font-size:130%}.hour-rain{font-size:115%}.updated-site{font-size:72%}
.loading,.error{font-size:calc(var(--type-ui) * .9)}footer{font-size:calc(var(--type-ui) * .68)}
.radar-modal{font-size:var(--type-ui)}.radar-title{font-size:220%}.radar-subtitle{font-size:86%}.radar-chip,.radar-control{font-size:76%}.radar-footer{font-size:70%}.leaflet-popup-content{font-size:85%}
</style>
